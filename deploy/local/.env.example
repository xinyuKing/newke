# MySQL base connection shared by forum and mall services.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=root
MYSQL_ROOT_PASSWORD=root

# Redis / Kafka / Nacos / RabbitMQ / Elasticsearch
REDIS_HOST=localhost
REDIS_PORT=6379
FORUM_REDIS_DATABASE=11
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
NACOS_SERVER_ADDR=127.0.0.1:8848
RABBIT_HOST=localhost
RABBIT_PORT=5672
RABBIT_USER=guest
RABBIT_PASS=guest
ELASTICSEARCH_URIS=http://127.0.0.1:9200
ES_JAVA_OPTS=-Xms512m -Xmx512m

# Shared JWT contract for gateway + mall services.
JWT_SECRET=change-this-secret-key-32-bytes-min
JWT_EXPIRE_MINUTES=120

# Local service URLs used by the unified gateway or internal service calls.
COMMUNITY_USER_BASE_URL=http://localhost:8081/community
FORUM_USER_SERVICE_URL=http://localhost:8081
FORUM_MESSAGE_SERVICE_URL=http://localhost:8082
FORUM_SOCIAL_SERVICE_URL=http://localhost:8083
FORUM_MEDIA_SERVICE_URL=http://localhost:8084
FORUM_DATA_SERVICE_URL=http://localhost:8085
FORUM_POST_SERVICE_URL=http://localhost:8086
MALL_AUTH_SERVICE_URL=http://localhost:18081
MALL_PRODUCT_SERVICE_URL=http://localhost:18082
MALL_INVENTORY_SERVICE_URL=http://localhost:18083
MALL_ORDER_SERVICE_URL=http://localhost:18084
MALL_CART_SERVICE_URL=http://localhost:18085
MALL_SUPPORT_SERVICE_URL=http://localhost:18086
PRODUCT_GRAY_URL=http://localhost:18082

# Forum runtime paths and browser-origin boundary.
COMMUNITY_PUBLIC_DOMAIN=http://localhost:8080
COMMUNITY_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
FORUM_UPLOAD_PATH=./runtime/community/upload
FORUM_MEDIA_PATH=./runtime/community/upload/media
FORUM_WK_STORAGE=./runtime/community/wk-images
WKHTMLTOIMAGE_COMMAND=wkhtmltoimage

# Optional third-party integrations.
FORUM_MAIL_HOST=smtp.163.com
FORUM_MAIL_PORT=465
FORUM_MAIL_PROTOCOL=smtps
FORUM_MAIL_USERNAME=
FORUM_MAIL_PASSWORD=
QINIU_ACCESS_KEY=
QINIU_SECRET_KEY=
QINIU_UPLOAD_HOST=https://upload-cn-east-2.qiniup.com
QINIU_HEADER_BUCKET=
QINIU_HEADER_BUCKET_URL=
QINIU_SHARE_BUCKET=
QINIU_SHARE_BUCKET_URL=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5-mini
OPENAI_API_KEY=
# Optional advanced service integrations.
SEARCH_PROVIDER=db
SEARCH_FALLBACK=true
OPENSEARCH_URL=
OPENSEARCH_INDEX=products
OPENSEARCH_USER=
OPENSEARCH_PASS=
LOGISTICS_PROVIDER=mock
LOGISTICS_API_URL=
LOGISTICS_API_KEY=
COMMUNITY_MODERATION_ENABLED=true
COMMUNITY_MODERATION_MODE=llm
