# Unified gateway during local integration.
VITE_GATEWAY_PROXY_TARGET=http://localhost:8080

# Optional: point the forum module to a dedicated backend when debugging.
VITE_FORUM_PROXY_TARGET=http://localhost:8080

# Optional: point the mall module to a dedicated backend when debugging.
VITE_MALL_PROXY_TARGET=http://localhost:8080

# Mall APIs default to /api in both dev and production. Override only when you need a custom base URL.
VITE_MALL_API_BASE=/api
